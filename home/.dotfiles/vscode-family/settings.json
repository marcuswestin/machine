{
  // Editor (appearance)
  /////////////////////////////
  "editor.fontSize": 12.5,
  "editor.lineHeight": 17,
  // "window.zoomLevel": 1.5, // Monitor extra large
  "window.zoomLevel": 1.3, // Monitor large
  // "window.zoomLevel": 0.8, // Monitor medium
  // "window.zoomLevel": 0.15, // Laptop

  // Vim
  /////////////////////////////
  "vim.insertModeKeyBindings": [{ "after": ["<Esc>"], "before": ["j", "j"] }],
  "vim.normalModeKeyBindingsNonRecursive": [
    // Route Vim undo/redo through VS Code so the tab dirty dot tracks reverted files.
    {
      "before": ["<C-r>"],
      "commands": ["redo"]
    },
    { "after": ["@", "@"], "before": ["Q"] },
    { "before": ["u"], "commands": ["undo"] }
  ],

  // Window, workbench, explorer
  /////////////////////////////
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "window.confirmSaveUntitledWorkspace": false,
  "workbench.colorTheme": "Dark Modern",
  "workbench.secondarySideBar.defaultVisibility": "visible",
  "workbench.startupEditor": "none",

  // Editor (general)
  /////////////////////////////
  "editor.defaultFormatter": "dprint.dprint",
  "editor.inlineSuggest.enabled": true,
  "editor.inlineSuggest.edits.showCollapsed": true,
  "editor.inlineSuggest.showToolbar": "always",
  "editor.minimap.enabled": false,
  "editor.quickSuggestions": { "comments": "on", "other": "on", "strings": "on" },
  "editor.renderWhitespace": "all",
  "editor.suggest.snippetsPreventQuickSuggestions": true,
  "editor.wordWrapColumn": 120,

  // Editor (format on save, imports, whitespace in files)
  /////////////////////////////
  "editor.codeActionsOnSave": { "source.addMissingImports": "explicit", "source.organizeImports": "explicit" },
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,

  // JavaScript & TypeScript (defaults)
  /////////////////////////////
  "javascript.suggest.completeFunctionCalls": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.format.enable": true,
  "typescript.implementationsCodeLens.enabled": true,
  "typescript.suggest.autoImports": true,
  "typescript.suggest.completeFunctionCalls": true,
  "typescript.suggest.completeJSDocs": true,
  "typescript.suggest.enabled": true,
  "typescript.updateImportsOnFileMove.enabled": "always",

  // Per-language editor overrides
  /////////////////////////////
  "[dockercompose]": {
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "[github-actions-workflow]": { "editor.defaultFormatter": "redhat.vscode-yaml" },
  "[json]": { "editor.defaultFormatter": "dprint.dprint" },
  "[jsonc]": { "editor.defaultFormatter": "dprint.dprint" },
  "[python]": { "editor.formatOnType": true },
  "[typescript]": { "editor.defaultFormatter": "dprint.dprint" },

  // Git
  /////////////////////////////
  "git.openRepositoryInParentFolders": "never",
  "git.suggestSmartCommit": false,

  // GitHub Copilot & inline AI
  /////////////////////////////
  "chat.disableAIFeatures": true,
  "claudeCode.preferredLocation": "panel",
  "continue.enableNextEdit": true,
  "continue.enableTabAutocomplete": true,
  "continue.showInlineTip": false,
  "github.copilot.enable": { "*": true, "markdown": false, "plaintext": true, "scminput": false },
  "github.copilot.nextEditSuggestions.enabled": true,
  "tabnine.experimentalAutoImports": true,

  // Telemetry & workspace security
  /////////////////////////////
  "redhat.telemetry.enabled": false,
  "security.promptForLocalFileProtocolHandling": false,
  "security.workspace.trust.untrustedFiles": "open",

  // JSON schemas, file associations, YAML
  /////////////////////////////
  "files.associations": { "*.just": "just" },
  "json.schemaDownload.trustedDomains": {
    "https://json-schema.org/": true,
    "https://json.schemastore.org/": true,
    "https://raw.githubusercontent.com/": true,
    "https://schemastore.azurewebsites.net/": true,
    "https://www.schemastore.org/": true
  },
  "yaml.schemas": {},

  // Cursor
  /////////////////////////////
  "cursor.composer.queueMessageDefaultBehavior": "stop-and-send",
  "cursor.composer.shouldChimeAfterChatFinishes": true,
  "cursor.cpp.disabledLanguages": ["scminput"],
  "cursor.inlineDiff.mode": "unified"
}
