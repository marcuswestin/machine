{
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "j"],
      "after": ["<Esc>"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["Q"],
      "after": ["@", "@"]
    }
  ],
  // Slight zoom-in for editor readability; VS Code/Cursor accept fractional zoom levels.
  "window.zoomLevel": 0.2,
  "window.confirmSaveUntitledWorkspace": false,
  "workbench.startupEditor": "none",
  "workbench.secondarySideBar.defaultVisibility": "visible",
  "workbench.colorTheme": "Dark Modern",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "editor.defaultFormatter": "biomejs.biome",
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "all",
  "editor.formatOnSave": true,
  "editor.wordWrapColumn": 120,
  "editor.inlineSuggest.enabled": true,
  "editor.inlineSuggest.edits.showCollapsed": true,
  "editor.inlineSuggest.showToolbar": "always",
  "editor.suggest.snippetsPreventQuickSuggestions": true,
  "editor.quickSuggestions": {
    "comments": "on",
    "strings": "on",
    "other": "on"
  },
  "editor.codeActionsOnSave": {
    "source.organizeImports.biome": "explicit"
  },
  "javascript.suggest.completeFunctionCalls": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.suggest.completeFunctionCalls": true,
  "typescript.suggest.enabled": true,
  "typescript.format.enable": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "[typescript]": {
    "editor.defaultFormatter": "dprint.dprint"
  },
  "[python]": {
    "editor.formatOnType": true
  },
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "git.openRepositoryInParentFolders": "never",
  "git.suggestSmartCommit": false,
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": false,
    "scminput": false
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "chat.disableAIFeatures": true,
  "continue.enableTabAutocomplete": true,
  "continue.enableNextEdit": true,
  "continue.showInlineTip": false,
  "claudeCode.preferredLocation": "panel",
  "tabnine.experimentalAutoImports": true,
  "redhat.telemetry.enabled": false,
  "security.workspace.trust.untrustedFiles": "open",
  "security.promptForLocalFileProtocolHandling": false,
  "json.schemaDownload.trustedDomains": {
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/": true,
    "https://www.schemastore.org/": true,
    "https://json.schemastore.org/": true,
    "https://json-schema.org/": true,
    "https://biomejs.dev": true
  },
  "files.associations": {
    "*.just": "just"
  },
  "cursor.cpp.disabledLanguages": ["scminput"],
  "cursor.composer.shouldChimeAfterChatFinishes": true,
  "cursor.composer.queueMessageDefaultBehavior": "stop-and-send",
  "cursor.inlineDiff.mode": "unified",
  "yaml.schemas": {}
}
