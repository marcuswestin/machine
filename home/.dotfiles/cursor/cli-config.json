{
  "version": 1,
  "editor": { "vimMode": false },
  "notifications": true,
  "hints": true,
  "rewind": false,
  "suggestNextPrompt": false,
  "hasChangedDefaultModel": false,
  "permissions": {
    "allow": [
      "Shell(./agent)",
      "Shell(bash:-n*)",
      "Shell(cd)",
      "Shell(chezmoi)",
      "Shell(cat)",
      "Shell(command)",
      "Shell(cp)",
      "Shell(curl)",
      "Shell(defaults)",
      "Shell(diff)",
      "Shell(dprint)",
      "Shell(echo)",
      "Shell(find)",
      "Shell(git)",
      "Shell(gzip)",
      "Shell(head)",
      "Shell(jq)",
      "Shell(just)",
      "Shell(ls)",
      "Shell(mdfind)",
      "Shell(mktemp)",
      "Shell(nix)",
      "Shell(od)",
      "Shell(osascript)",
      "Shell(plutil)",
      "Shell(printf)",
      "Shell(rg)",
      "Shell(sed)",
      "Shell(sort)",
      "Shell(sqlite3)",
      "Shell(strings)",
      "Shell(tail)",
      "Shell(taplo)",
      "Shell(test)",
      "Shell(tr)",
      "Shell(true)",
      "Shell(wc)"
    ],
    "deny": []
  },
  "approvalMode": "allowlist",
  "terminalAllowlist": [
    "./agent",
    "cd",
    "head",
    "git push",
    "just",
    "git status",
    "nix",
    "curl",
    "jq",
    "dprint",
    "tail",
    "echo",
    "osascript",
    "defaults",
    "rg",
    "plutil",
    "wc",
    "find",
    "ls",
    "strings",
    "sort",
    "mdfind",
    "tr",
    "sqlite3",
    "git add",
    "gzip",
    "mktemp",
    "test",
    "true",
    "printf",
    "command",
    "cp",
    "diff",
    "taplo",
    "cat",
    "od",
    "sed",
    "bash -n",
    "chezmoi"
  ],
  "mcpAllowlist": [],
  "sandbox": { "mode": "disabled", "networkAccess": "user_config_with_defaults" },
  "runEverythingSettingsPromptStreak": 0,
  "network": { "useHttp1ForAgent": false },
  "webFetchDomainAllowlist": [
    "api.github.com",
    "cdn.jsdelivr.net",
    "docs.docker.com",
    "docs.rs",
    "dprint.dev",
    "gist.githubusercontent.com",
    "github.com",
    "handy.computer",
    "iterm2.com",
    "just.systems",
    "manual.raycast.com",
    "nikitabobko.github.io",
    "plugins.dprint.dev",
    "raw.githubusercontent.com",
    "registry.npmjs.org",
    "taplo.tamasfe.dev",
    "unpkg.com"
  ],
  "attribution": { "attributeCommitsToAgent": true, "attributePRsToAgent": true }
}
