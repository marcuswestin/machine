{
  "typescript": {},
  "json": {
    "jsonTrailingCommaFiles": ["**/.vscode/settings.json", "**/vscode-family/settings.json"],
    "lineWidth": 120,
    "preferSingleLine": false,
    "trailingCommas": "jsonc"
  },
  "markdown": {},
  "toml": {},
  "dockerfile": {},
  "biome": {},
  "oxc": {},
  "jupyter": {},
  "ruff": {},
  "mago": {},
  "malva": {},
  "markup": {},
  "yaml": {},
  "graphql": {},
  "prettier": {},
  "roslyn": {},
  "exec": {
    "cwd": "${configDir}",
    "commands": [
      {
        "command": "just --dump --dump-format just --justfile {{file_path}}",
        "stdin": false,
        "fileNames": ["Justfile", "justfile"]
      }
    ]
  },
  "excludes": ["**/node_modules", "**/*-lock.json"],
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.96.0.wasm",
    "https://plugins.dprint.dev/json-0.21.3.wasm",
    "https://plugins.dprint.dev/markdown-0.21.1.wasm",
    "https://plugins.dprint.dev/toml-0.7.0.wasm",
    "https://plugins.dprint.dev/dockerfile-0.3.3.wasm",
    "https://plugins.dprint.dev/biome-0.12.11.wasm",
    "https://plugins.dprint.dev/oxc-0.21.0.wasm",
    "https://plugins.dprint.dev/jupyter-0.2.2.wasm",
    "https://plugins.dprint.dev/ruff-0.7.11.wasm",
    "https://plugins.dprint.dev/mago-0.18.0.wasm",
    "https://plugins.dprint.dev/g-plane/malva-v0.15.3.wasm",
    "https://plugins.dprint.dev/g-plane/markup_fmt-v0.27.1.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_graphql-v0.2.3.wasm",
    "https://plugins.dprint.dev/exec-0.6.2.json@df98f54ffd3092b8a841aedd6d098a2651f16d0a796a40535774f1a8b4b9d463",
    "https://plugins.dprint.dev/prettier-0.69.0.json@3de5c7cf5cdbae7b214f404b12503c92e7964be5fffd442b998e6d5fe4ba0e7b",
    "https://plugins.dprint.dev/roslyn-0.20.1.json@19d542734f015097dbed728ca7ae6a96af3a97d7dddd81a0f94b5c4f69217fa4"
  ]
}
