# Generated by chezmoi from machine repo on first install only. Marketplace paths are
# app-managed and machine-local; do not commit `~/.codex/auth.json` or SQLite caches.

model = "gpt-5.5"
model_reasoning_effort = "high"
personality = "pragmatic"

# Named sandbox profile for CLI/app/extension (OpenAI cloud APIs + workspace tools). See:
# https://developers.openai.com/codex/advanced-configuration/#named-permission-profiles
default_permissions = "workspace"

[desktop]
# Codex → Settings → General → Power: prevent sleep while a chat is running.
preventSleepWhileRunning = true
# Codex → Settings → Notifications → Turn completion notifications: Always.
"notifications-turn-mode" = "always"

[permissions.workspace.filesystem]
":project_roots" = { "." = "write", "**/.env*" = "none", "**/.env.*" = "none" }

[permissions.workspace.network]
enabled = true
mode = "limited"

[permissions.workspace.network.domains]
"api.openai.com" = "allow"

[plugins."documents@openai-primary-runtime"]
enabled = true

[plugins."spreadsheets@openai-primary-runtime"]
enabled = true

[plugins."presentations@openai-primary-runtime"]
enabled = true

[plugins."browser-use@openai-bundled"]
enabled = true

[projects."{{ .chezmoi.homeDir }}/code/machine"]
trust_level = "trusted"

[projects."{{ .chezmoi.homeDir }}/code/tao-lang"]
trust_level = "trusted"

[projects."{{ .chezmoi.homeDir }}/code/git-star"]
trust_level = "trusted"

[features]
memories = true

[memories]
generate_memories = true
use_memories = true
