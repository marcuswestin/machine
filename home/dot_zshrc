# Prompt
PROMPT='%~ λ '

# Home Manager session vars (appear after `home-manager switch` / `just up`)
if [[ -r "$HOME/.nix-profile/etc/profile.d/hm-session-vars.sh" ]]; then
  . "$HOME/.nix-profile/etc/profile.d/hm-session-vars.sh"
fi

# Homebrew — only wire completions when `_brew` exists (avoids compinit errors on partial installs)
if command -v brew >/dev/null 2>&1; then
  eval "$(brew shellenv)"
  if [[ -n "${HOMEBREW_PREFIX:-}" && -r "$HOMEBREW_PREFIX/share/zsh/site-functions/_brew" ]]; then
    fpath=("$HOMEBREW_PREFIX/share/zsh/site-functions" $fpath)
  fi
fi

# ZSH completions
fpath=("$HOME/.zsh-completions" $fpath)

# Stale ~/.zcompdump can reference removed Homebrew completion files
if [[ -f "$HOME/.zcompdump" && -n "${HOMEBREW_PREFIX:-}" ]] &&
  ! [[ -r "$HOMEBREW_PREFIX/share/zsh/site-functions/_brew" ]]; then
  rm -f "$HOME"/.zcompdump*(N)
fi

autoload -U compinit
compinit

# Aliases
alias j="just"

if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook zsh)"
fi
