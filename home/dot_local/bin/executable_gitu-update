#!/bin/bash

# What: Pull from origin for the given branch (default: current branch)
# Usage: gitu-update [branch]
# Examples:
#> gitu-update
#> gitu-update master

set -e
cd "$(git rev-parse --show-toplevel)"

REMOTE="origin"

if [[ $# -gt 1 ]]; then
	echo "Usage: gitu-update [branch]" >&2
	exit 2
fi

if [[ -n "${1:-}" ]]; then
	BRANCH="$1"
else
	BRANCH="$(git branch --show-current)"
	if [[ -z "$BRANCH" ]]; then
		echo "Cannot infer current branch while HEAD is detached; pass branch name" >&2
		exit 2
	fi
fi

git checkout "$BRANCH"

echo "Update git repo $(pwd) from $REMOTE/$BRANCH"
git pull "$REMOTE" "$BRANCH"
git submodule sync
git submodule update --init --recursive
